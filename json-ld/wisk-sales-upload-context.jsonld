{
  "@context": {
    "@version": 1.1,
    "wisk": "https://wisk.ai/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "SalesLine": "wisk:SalesLine",
    "id": {
      "@id": "wisk:id",
      "@type": "xsd:string"
    },
    "date": {
      "@id": "wisk:date",
      "@type": "xsd:dateTime"
    },
    "pluNumber": {
      "@id": "wisk:plu_number",
      "@type": "xsd:string"
    },
    "title": {
      "@id": "schema:name",
      "@type": "xsd:string"
    },
    "quantity": {
      "@id": "wisk:quantity",
      "@type": "xsd:double"
    },
    "total": {
      "@id": "wisk:total",
      "@type": "xsd:double"
    }
  }
}
